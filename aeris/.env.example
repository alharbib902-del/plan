# ============================================
# AERIS ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# ===== PUBLIC (Client-accessible) =====
NEXT_PUBLIC_SITE_URL=https://aeris.sa
NEXT_PUBLIC_APP_NAME=Aeris

# Supabase (Public anon key - safe for client)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxx

# WhatsApp (visible on site)
NEXT_PUBLIC_WHATSAPP_NUMBER=966558048004

# ===== SERVER-ONLY (Keep secret) =====

# Supabase (Service role - admin access)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxx

# Anthropic (Claude API for automation)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@aeris.sa

# WhatsApp (wasenderapi.com) — Phase 8.1
# Used by lib/notifications/whatsapp-provider.ts to deliver
# operator welcome + password reset links + OTP codes over
# WhatsApp in parallel with email. Without WASENDER_API_KEY the
# provider returns 'config_missing' and the admin banner surfaces
# it; email continues to ship unaffected.
# WASENDER_API_BASE_URL is optional; defaults to
# https://www.wasenderapi.com (override only for staging proxy).
#
# WASENDER_TRIAL_RATE_LIMIT_ENABLED gates the in-memory
# 1-msg/min/account guard that protects the wasender trial
# budget. Default ON (any value other than 'false'). Flip to
# 'false' AFTER subscription upgrade removes the trial cap on
# the wasender side — otherwise paid welcome/reset/OTP sends
# stay artificially throttled. (Codex round 2 PR #46 P2 fix.)
WASENDER_API_KEY=
WASENDER_API_BASE_URL=https://www.wasenderapi.com
WASENDER_TRIAL_RATE_LIMIT_ENABLED=true

# Lead notification email (Phase 2). Falls back to RESEND_FROM_EMAIL when unset.
LEAD_NOTIFICATION_TO=

# SMS (Unifonic)
UNIFONIC_APP_SID=xxxxxxxxxxxx
UNIFONIC_SENDER_ID=Aeris

# Payment (HyperPay)
HYPERPAY_ACCESS_TOKEN=xxxxxxxxxxxx
HYPERPAY_ENTITY_ID_MADA=xxxxxxxxxxxx
HYPERPAY_ENTITY_ID_VISA=xxxxxxxxxxxx
HYPERPAY_ENTITY_ID_APPLE=xxxxxxxxxxxx
HYPERPAY_WEBHOOK_SECRET=xxxxxxxxxxxx
HYPERPAY_MODE=test
# HYPERPAY_MODE=live (for production)

# ZATCA (E-invoicing)
ZATCA_API_URL=https://gw-fatoora.zatca.gov.sa
ZATCA_OTP=xxxxxxxxxxxx
ZATCA_CERTIFICATE=xxxxxxxxxxxx

# Inngest (Workflows)
INNGEST_EVENT_KEY=xxxxxxxxxxxx
INNGEST_SIGNING_KEY=xxxxxxxxxxxx

# Sentry (REA-01 error monitoring). Fully a no-op until a DSN is set.
# NEXT_PUBLIC_SENTRY_DSN is REQUIRED for browser + error-boundary capture; it is
# inlined into the client bundle at BUILD time, so changing it needs a redeploy.
# SENTRY_DSN (server-only) is optional — the server falls back to the public DSN.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxx@o0.ingest.sentry.io/0
SENTRY_DSN=
# Source-map upload (readable stack traces) runs at build time ONLY when all
# three are set; otherwise it is skipped silently and the build stays green.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional tracing sample rate in [0,1]; default 0 = errors only.
SENTRY_TRACES_SAMPLE_RATE=0

# Admin (Initial admin credentials — Phase 3, full Supabase Auth)
ADMIN_EMAIL=admin@aeris.sa
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_IMMEDIATELY

# Phase 2 admin inbox (placeholder shared-password gate). Set BOTH to enable.
# Generate ADMIN_AUTH_SECRET with: openssl rand -hex 32
ADMIN_INBOX_PASSWORD=
ADMIN_AUTH_SECRET=

# Phase 4 operator-link signing secret. Required for the operator
# offer page (/operator/offer/[token]). Generate with:
#   openssl rand -hex 32
# DO NOT reuse ADMIN_AUTH_SECRET — different lifecycle and blast radius.
OPERATOR_TOKEN_SECRET=

# Phase 6.2 customer-checkout signing secret. Required by PR 2b's
# customer checkout-prep page (/booking/[token]/checkout-prep) and
# admin "Issue customer checkout link" action. Generate per
# environment with:
#   openssl rand -base64 32
# DO NOT share the value across Production / Preview / Development —
# mint and verify always run within the same environment, and
# environment-distinct secrets minimize blast radius if any one leaks
# (Codex iteration-5 P2 #2 fix). Module is fail-closed: missing /
# empty value → mint throws, verify returns null, customer page
# renders the "expired or not-issued" surface (no 5xx leak).
CUSTOMER_CHECKOUT_SECRET=

# Phase 6.2 admin debug smoke route gate. External URL:
#   /admin/debug/customer-token-smoke
# (Spec drafts said `_debug/...`; Next.js App Router excludes
# `_`-prefixed folders from routing, so the implementation
# uses `debug/...`. PR 1 work-log documents the deviation.)
# Default off (route returns 404). Set to `true` only during
# the founder pre-flight gate window between PR 2a probes
# and PR 2b open, then flip back to `false`. The route runs
# a mint→verify round-trip with a UUID v4 sentinel to
# confirm CUSTOMER_CHECKOUT_SECRET is hooked up in the
# current environment. Codex iteration-10 P1 + P2 #2 fix +
# round-14 P2 docs fix.
ENABLE_CHECKOUT_TOKEN_DEBUG=false

# Flight Data (optional)
FLIGHTRADAR24_API_KEY=xxxxxxxxxxxx
ACCUWEATHER_API_KEY=xxxxxxxxxxxx

# ============================================
# PHASE 7 — Empty Legs marketplace
# ============================================

# Feature flags. PR 2b (admin) defaults `true` once PR 2a is on
# production; the page modules and Server Actions explicitly
# fail-closed when this is set to `false`. PR 2c (operator) and
# PR 2d (public marketplace) default `false` until their
# respective PRs ship.
ENABLE_EMPTY_LEGS_ADMIN_UI=true
ENABLE_EMPTY_LEGS_PUBLIC_MARKETPLACE=false
ENABLE_OPERATOR_PORTAL=false

# 2026-06 request-to-book — client-facing empty-leg prices are HIDDEN
# (fail-closed) unless this is `true`: clients see the leg + discount %,
# send a reservation request, and Aeris sends the price after a
# seriousness check. Hides prices on cards/detail/reserve pages, the
# /me portal, and strips SAR amounts from client emails + wa.me bodies.
# Operator/admin surfaces always show prices.
ENABLE_EMPTY_LEGS_CLIENT_PRICING=false

# PR 2d — `NEXT_PUBLIC_*` mirror of the server-side flag,
# read by the public site header to surface the
# "رحلات فارغة" nav entry. The server-side flag is the
# enforcement boundary — Server Actions + page modules
# notFound() when off, regardless of the NEXT_PUBLIC_* twin.
NEXT_PUBLIC_ENABLE_EMPTY_LEGS_PUBLIC_MARKETPLACE=false

# PR 2e — Match-trigger / candidate-pool kill switch (Codex
# iteration-2 P1 #2 fix). When `false`, the matching engine
# fail-closes BEFORE any candidate-pool read or audit-row
# INSERT (Codex iteration-5 P2 #1 fix). Default off until
# PR 2e ships and the canary-flip plan flips both this and
# the public-marketplace flag together.
ENABLE_EMPTY_LEGS_NOTIFICATIONS=false

# Optional AI-scoring kill switch (PR 2e candidate scoring).
# When `false`, matching falls back to rule-based scoring
# without Anthropic calls.
ENABLE_EMPTY_LEGS_AI_SCORING=false

# HMAC token secrets — separate per surface for rotation
# independence (mirrors Phase 6.2's CUSTOMER_CHECKOUT_SECRET
# discipline). Generate each with `openssl rand -base64 32`
# per environment; never share values across Production /
# Preview / Development.
EMPTY_LEGS_OPERATOR_TOKEN_SECRET=
EMPTY_LEGS_RESERVATION_TOKEN_SECRET=
EMPTY_LEGS_OPT_OUT_TOKEN_SECRET=

# Founder batch-email recipient for the wa.me dispatch alert
# (Codex iteration-4 P1 #1 fix). Falls back to
# LEAD_NOTIFICATION_TO when unset.
EMPTY_LEGS_FOUNDER_BATCH_EMAIL_TO=

# Cron-route auth (PR 2e). Required by every
# /api/cron/empty-legs/... endpoint AND the synchronous
# match-trigger fire-and-forget from
# `adminPublishEmptyLeg` / `operatorPublishEmptyLeg`.
# Generate with `openssl rand -hex 32`.
#
# SCHEDULING: PR 2e ships 4 cron-style routes
# (dutch-auction-tick / expire-reservations /
# expire-windows / match-drain) but does NOT register
# them in vercel.json — Vercel Hobby plan limits cron
# expressions to once-per-day, which would break the
# 5-min reservation expiry + 30-min auction tick
# contracts. Pick ONE of the following before flipping
# the marketplace flags:
#
#   1. Vercel Pro ($20/mo) — re-add the 4 cron entries
#      from PR 2e §vercel.json (the diff is in PR #33's
#      git history). Per-minute scheduling unlocks.
#   2. External scheduler (cron-job.org / EasyCron /
#      GitHub Actions schedule) — call each route via
#      GET with `Authorization: Bearer <CRON_SECRET>`
#      at the schedule documented in the route's
#      docstring (every 30min / 5min / hourly / 30min
#      respectively). cron-job.org is free with
#      per-minute precision.
#   3. Run manually for a small smoke + canary window —
#      curl each route by hand. Not viable for steady
#      production use.
#
# All four routes are idempotent and safe to re-invoke;
# the IS NULL guards on outbox + reservation columns
# prevent double-processing under any scheduler choice.
CRON_SECRET=

# ============================================
# PHASE 8 — Operator account onboarding
# ============================================

# Phase 8 PR 2b admin nav-entry kill switch. Fail-closed:
# the admin operators surface is OFF unless this is the
# literal `'true'` (set it here to keep the surface on).
# Every admin Server Action + page module short-circuits
# with notFound() / { ok: false, error: 'flag_disabled' }
# unless this is `'true'`.
ENABLE_OPERATOR_PORTAL_ADMIN=true

# Phase 8 PR 2c operator-portal kill switch. Fail-closed: the
# public signup / login / dashboard are OFF unless this is the
# literal `'true'`. Phase 8 admin (PR 2b) does NOT depend on
# this — admin can approve / reject / manage operator rows even
# with the operator-facing portal disabled.
ENABLE_OPERATOR_PORTAL=false

# Phase 8 PR 2c legacy-token kill switch. The Phase 7
# token-URL operator flow stays available behind this flag
# during the canary window; flip to `false` to retire it
# after operators migrate to the new session-based portal.
ENABLE_OPERATOR_LEGACY_TOKEN=true

# HMAC secrets — separate per surface for rotation
# independence (mirrors Phase 7 secret discipline). Generate
# each per environment with `openssl rand -base64 32`; never
# share values across Production / Preview / Development.
# Each module is fail-closed: missing/empty value -> mint
# throws, verify returns { valid: false, reason: 'env_missing' }.
#
# OPERATOR_WELCOME_TOKEN_SECRET   — magic-link first-login
#                                   token (PR 2b adminApproveOperator
#                                   mints; PR 2c /operator/welcome/<token>
#                                   page consumes via
#                                   consume_operator_welcome_token RPC).
# OPERATOR_PASSWORD_RESET_TOKEN_SECRET — email reset link
#                                   (PR 2c /operator/forgot-password
#                                   form mints; verify_operator_password_reset
#                                   RPC consumes).
# OPERATOR_OTP_SECRET             — reserved for PR 2c WhatsApp
#                                   OTP HMAC (admin mints code in
#                                   PR 2b adminMintOperatorOtp;
#                                   verify happens in
#                                   verify_operator_otp RPC).
# OPERATOR_SESSION_SECRET         — cookie value HMAC for the
#                                   `aeris_operator` session cookie
#                                   (PR 2c lib/operators/auth.ts).
OPERATOR_WELCOME_TOKEN_SECRET=
OPERATOR_PASSWORD_RESET_TOKEN_SECRET=
OPERATOR_OTP_SECRET=
OPERATOR_SESSION_SECRET=

# Phase 9 PR 1 — client portal
#
# ENABLE_CLIENT_PORTAL                       — fail-closed
#                                              kill-switch (Codex
#                                              round 1 PR #55 P2 #2
#                                              fix). The portal +
#                                              Server Actions render
#                                              ONLY when this env is
#                                              the literal string
#                                              `true`. Any other
#                                              value (unset, empty,
#                                              `1`, `yes`, typo)
#                                              keeps the portal
#                                              hidden so a missing-
#                                              env deploy never
#                                              exposes /login,
#                                              /signup, or
#                                              clientSignup before
#                                              the migration applies.
# CLIENT_PASSWORD_RESET_TOKEN_SECRET         — HMAC secret for the
#                                              30-min client reset
#                                              token. Generate with:
#                                                openssl rand -hex 32
#                                              MUST be distinct from
#                                              OPERATOR_PASSWORD_RESET_
#                                              TOKEN_SECRET (separate
#                                              populations, separate
#                                              blast radius).
ENABLE_CLIENT_PORTAL=false
CLIENT_PASSWORD_RESET_TOKEN_SECRET=

# Phase 9 PR 4 — auto-distribution engine
#
# ENABLE_TRIP_AUTO_DISTRIBUTION              — fail-closed
#                                              kill-switch for
#                                              the auto-dispatch
#                                              fire-and-forget
#                                              call inside
#                                              createAuthenticatedTripRequest
#                                              (Phase 9 spec §5
#                                              PR 2 + Codex round 1
#                                              P1 #3 alignment).
#                                              Default OFF until
#                                              probes 16 + 17 pass
#                                              on production. While
#                                              off, trips land in
#                                              `pending` for manual
#                                              admin dispatch via
#                                              DispatchPanelV2.
# PHASE_9_MIN_DISPATCH_FANOUT                — minimum unique
#                                              dispatch targets
#                                              (post-phone-dedupe)
#                                              required for
#                                              auto_dispatch_trip_request
#                                              to open a round
#                                              instead of returning
#                                              insufficient_unique_operators.
#                                              Default 2 (no
#                                              competition pressure
#                                              with 1 target).
ENABLE_TRIP_AUTO_DISTRIBUTION=false
PHASE_9_MIN_DISPATCH_FANOUT=2

# TRIP_REDISPATCH_STALE_HOURS                — staleness
#                                              threshold (in
#                                              hours, FRACTIONAL
#                                              accepted) used by
#                                              the redispatch
#                                              cron's two-phase
#                                              scan: open
#                                              dispatch rounds
#                                              older than this
#                                              (Phase A) AND
#                                              PR-2 client-portal
#                                              trips with status=
#                                              'pending' and no
#                                              round whose
#                                              created_at is
#                                              older than this
#                                              (Phase B). Default
#                                              4. Probe 18 lowers
#                                              this to 0.01
#                                              (~36 seconds) for a
#                                              fast production
#                                              smoke (Codex PR #58
#                                              round 1 P2 #4 +
#                                              round 2 P2 #4 fix —
#                                              parsed as parseFloat
#                                              so fractional
#                                              values survive).
#                                              The cron route
#                                              ALSO honours
#                                              ENABLE_TRIP_AUTO_DISTRIBUTION:
#                                              when that flag is
#                                              off, the cron
#                                              records a
#                                              skipped tick and
#                                              never touches a
#                                              trip (Codex round
#                                              2 PR #58 P1 #1
#                                              fix).
TRIP_REDISPATCH_STALE_HOURS=4
